---
import CTAButton from './CTAButton.astro';
const base = import.meta.env.BASE_URL;
---

<section class="bg-[#FAF6EE] relative overflow-hidden">
  <!-- Gold bar top -->
  <div class="h-2 bg-[#C8891A]"></div>

  <div class="container mx-auto px-6 pt-8 pb-10 max-w-3xl">

    <!-- Logo -->
    <div class="text-center mb-5">
      <img
        src={`${base}images/logo.png`}
        alt="Minicozzi ChefLab"
        class="mx-auto h-28 md:h-36 w-auto"
        onerror={`this.onerror=null;this.src='${base}images/logo-placeholder.svg';`}
      />
    </div>

    <!-- Pre-headline -->
    <div class="text-center mb-4">
      <span class="inline-block bg-[#C8891A] text-white font-black tracking-widest uppercase text-sm px-6 py-2 rounded-sm" style="font-family: 'Lato', sans-serif;">
        Ristoratore!
      </span>
    </div>

    <!-- Headline letter-style -->
    <div class="text-center mb-4">
      <p class="text-[#1C1A14] text-lg md:text-xl leading-relaxed" style="font-family: 'Playfair Display', serif;">
        In Campania la pasta fresca è sacra,<br class="hidden md:block"/>
        ecco perché <strong>non puoi commettere errori</strong>.<br/>
        I clienti se ne accorgono. I colleghi parlano.
      </p>
      <p class="mt-3 text-[#8A8070] text-base italic" style="font-family: 'Playfair Display', serif;">
        Ti presento…
      </p>
    </div>

    <!-- Main headline -->
    <div class="text-center mb-3">
      <h1 class="text-3xl md:text-5xl font-black text-[#1C1A14] leading-tight" style="font-family: 'Playfair Display', serif;">
        <span class="text-[#C8891A]">Minicozzi</span> Chef<span class="text-[#C8891A]">Lab</span>
      </h1>
      <p class="text-lg md:text-xl font-semibold text-[#3D3828] mt-1 italic" style="font-family: 'Playfair Display', serif;">
        Pasta fresca su misura in 72 ore
      </p>
      <p class="text-sm md:text-base font-bold text-[#8A8070] uppercase tracking-widest mt-1" style="font-family: 'Lato', sans-serif;">
        L'unica con la garanzia <span class="text-[#8B2020]">"Servizio Salvato"</span>
      </p>
    </div>

    <!-- Ornament -->
    <div class="flex items-center justify-center gap-4 my-5">
      <div class="h-px bg-[#C8891A]/40 flex-1"></div>
      <span class="text-[#C8891A] text-lg">✦</span>
      <div class="h-px bg-[#C8891A]/40 flex-1"></div>
    </div>

    <!-- Offer box -->
    <div class="border-2 border-[#C8891A] rounded-sm px-6 py-5 text-center mb-2">
      <p class="text-[#C8891A] uppercase tracking-widest text-sm font-bold mb-2" style="font-family: 'Lato', sans-serif;">
        Occasione limitata a pochi ristoratori
      </p>
      <p class="text-xl md:text-2xl font-bold text-[#1C1A14] leading-snug mb-1" style="font-family: 'Playfair Display', serif;">
        Prova <span class="text-[#C8891A]">GRATIS</span> la pasta fresca di Minicozzi Chef Lab<br/>
        per un'intera giornata di servizio
      </p>
      <p class="text-[#3D3828] text-sm md:text-base" style="font-family: 'Lato', sans-serif;">
        Scegli tu quanti kg di pasta ti servono. <u>Attenzione: è un'occasione limitata a pochi ristoratori!</u>
      </p>
    </div>

    <CTAButton size="large" />

    <p class="text-center text-[#8A8070] text-sm italic -mt-4" style="font-family: 'Lato', sans-serif;">
      Nessun impegno. Nessuna carta di credito. Solo pasta fresca vera.
    </p>

  </div>

  <!-- Gold bar bottom -->
  <div class="h-2 bg-[#C8891A]"></div>
</section>

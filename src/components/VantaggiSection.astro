---
const vantaggi = [
  {
    icon: "🎨",
    title: "Formato 100% su misura",
    desc: "Spaghetti alla chitarra, paccheri giganti, scialatielli spessi, fusilli custom: se puoi immaginarlo, possiamo farlo. Il tuo formato diventa un'esclusiva."
  },
  {
    icon: "🌾",
    title: "Materie prime campane DOC",
    desc: "Semola di grano duro Senatore Cappelli, uova fresche a km zero, acqua del Cilento. Nessun additivo. Nessun compromesso."
  },
  {
    icon: "🤝",
    title: "Garanzia \"Servizio Salvato\"",
    desc: "Se la nostra pasta non supera il servizio come promesso, rifacciamo l'ordine entro 24h — gratis. Il tuo servizio non si ferma mai per colpa nostra."
  },
  {
    icon: "📊",
    title: "Quantità su richiesta",
    desc: "Da 20 kg a più di una tonnellata. Che tu gestisca un ristorante fine dining o un grande catering, la proporzione è sempre perfetta."
  },
  {
    icon: "🔬",
    title: "Tracciabilità certificata",
    desc: "Ogni lotto viene documentato con materie prime, data di produzione e scheda nutrizionale. Perfetto per HACCP e menu trasparenti."
  },
  {
    icon: "💬",
    title: "Un referente dedicato",
    desc: "Niente call center. Hai un numero diretto del responsabile produzione. Parli con chi decide e chi fa la pasta."
  },
];
---

<section class="py-20 bg-[#EDE5CF]">
  <div class="max-w-5xl mx-auto px-6">

    <div class="text-center mb-14">
      <p class="text-[#C8891A] uppercase tracking-widest text-sm font-bold mb-3" style="font-family: 'Lato', sans-serif;">Perché scegliere Minicozzi</p>
      <h2 class="text-3xl md:text-4xl font-bold text-[#1C1A14]" style="font-family: 'Playfair Display', serif;">
        Non è solo pasta.<br/>
        <span class="italic">È il tuo standard di qualità.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {vantaggi.map((v) => (
        <div class="bg-[#FAF6EE] border border-[#C8891A]/20 rounded-sm p-6 hover:border-[#C8891A]/60 transition-colors duration-200">
          <span class="text-4xl block mb-4">{v.icon}</span>
          <h3 class="text-lg font-bold text-[#1C1A14] mb-2" style="font-family: 'Playfair Display', serif;">{v.title}</h3>
          <p class="text-[#3D3828] text-sm leading-relaxed" style="font-family: 'Lato', sans-serif;">{v.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>

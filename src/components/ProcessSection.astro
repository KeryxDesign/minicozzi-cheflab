---
import CTAButton from './CTAButton.astro';

const steps = [
  { n:"1", icon:"💬", title:"Scrivimi su WhatsApp.", desc:"Mi dai poche info: tipo di ristorante, coperti medi, zona. Ci vuole un minuto." },
  { n:"2", icon:"📞", title:"Ti richiamo io — di persona.", desc:"Non un assistente, non un call center. Parliamo di cucina, di numeri, di quello che ti serve davvero." },
  { n:"3", icon:"📋", title:"Definiamo la giornata di prova.", desc:"Quando farla, quanti kg, quali formati testare. Tutto su misura." },
  { n:"4", icon:"🍝", title:"Ti arriva la pasta. La metti in servizio.", desc:"Cucini per i tuoi clienti. Io sono reperibile se serve qualcosa." },
  { n:"5", icon:"🤝", title:"Decidi tu.", desc:"Se divento il tuo partner, bene. Se no — avrai comunque fatto un servizio con pasta fresca su misura, gratis." },
];
---

<section class="py-20 bg-carta">
  <div class="max-w-2xl mx-auto px-6">

    <div class="text-center mb-12">
      <p class="text-[#C8891A] uppercase tracking-widest text-base font-bold mb-4" style="font-family: 'Lato', sans-serif;">Come funziona in pratica</p>
      <h2 class="text-3xl md:text-4xl font-bold text-[#1C1A14]" style="font-family: 'Playfair Display', serif;">
        Cinque passi.<br/>
        <span class="italic text-[#C8891A]">Nessun contratto da firmare.</span>
      </h2>
    </div>

    <div class="relative mb-12">
      <!-- Vertical timeline line -->
      <div class="absolute left-[21px] top-6 bottom-6 w-0.5 bg-[#C8891A]/30"></div>

      <div class="space-y-0">
        {steps.map((step, i) => (
          <div class="relative flex items-start gap-5 pl-0 py-4">
            <!-- Number badge on the line -->
            <div class="relative z-10 w-11 h-11 rounded-full bg-[#C8891A] text-white font-black text-xl flex items-center justify-center flex-shrink-0 shadow-md" style="font-family: 'Playfair Display', serif;">
              {step.n}
            </div>
            <!-- Content -->
            <div class="flex-1 bg-[#FAF6EE] rounded-sm p-5 shadow-sm border-l-2 border-[#C8891A]/20">
              <p class="font-bold text-[#1C1A14] text-lg mb-1" style="font-family: 'Lato', sans-serif;"><span class="mr-2" aria-hidden="true">{step.icon}</span>{step.title}</p>
              <p class="text-[#3D3828] text-base leading-relaxed" style="font-family: 'Lato', sans-serif;">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="border-2 border-[#8B2020] rounded-sm p-8 mb-12 text-center">
      <p class="text-[#8B2020] font-black uppercase tracking-widest text-base mb-3" style="font-family: 'Lato', sans-serif;">Attenzione</p>
      <p class="text-[#1C1A14] text-xl leading-relaxed font-bold" style="font-family: 'Lato', sans-serif;">
        Accetto solo un numero limitato di ristoranti ogni mese.
      </p>
      <p class="text-[#3D3828] text-lg mt-3" style="font-family: 'Lato', sans-serif;">
        Per mantenere la qualità del prodotto e del servizio, accetto solo un numero limitato di ristoranti ogni mese tra i miei clienti. Non posso seguire tutti — voglio seguire bene chi lavora con me.
      </p>
    </div>

    <CTAButton size="large" />
  </div>
</section>

---
const waMsg = encodeURIComponent("Ciao Gianfranco! Ho letto del Minicozzi Chef Lab e mi interessa la prova gratuita. Possiamo parlare?");
const waUrl = `https://wa.me/393381694969?text=${waMsg}`;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<section id="prova-gratis" class="py-24 bg-carta">
  <div class="max-w-2xl mx-auto px-6 text-center">

    <span class="inline-block bg-[#8B2020] text-white text-base font-black uppercase tracking-widest px-5 py-2 rounded-sm mb-8" style="font-family: 'Lato', sans-serif;">
      Posti limitati — Offerta esclusiva
    </span>

    <h2 class="text-3xl md:text-4xl font-bold text-[#1C1A14] mb-4" style="font-family: 'Playfair Display', serif;">
      Chiedi la tua giornata<br/>
      <span class="italic text-[#C8891A]">di pasta in regalo</span>
    </h2>

    <p class="text-[#3D3828] text-xl leading-relaxed mb-4" style="font-family: 'Lato', sans-serif;">
      Scrivi su WhatsApp adesso.
    </p>
    <p class="text-[#3D3828] text-xl leading-relaxed mb-10" style="font-family: 'Lato', sans-serif;">
      Gianfranco risponde di persona — non un call center, non un assistente.
    </p>

    <!-- WhatsApp CTA -->
    <a
      href={waUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center gap-4 bg-[#25D366] hover:bg-[#1ebe5d] text-white text-xl md:text-2xl font-black px-10 py-6 rounded-sm shadow-xl transition-all duration-200 hover:shadow-2xl hover:-translate-y-1 cursor-pointer w-full md:w-auto"
      style="font-family: 'Lato', sans-serif; letter-spacing: 0.03em;"
    >
      <svg class="w-8 h-8 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Sì, voglio provare GRATIS Minicozzi Chef Lab
    </a>

    <p class="text-[#8A8070] text-base mt-4 italic" style="font-family: 'Lato', sans-serif;">
      Ti rispondo entro poche ore. Nessun impegno.
    </p>

    <!-- Foto Gianfranco con chef -->
    <div class="mt-10 mb-6 rounded-sm overflow-hidden shadow-md">
      <img
        src={`${base}images/gianfranco-cucina.jpg`}
        alt="Gianfranco Ranaldo nel laboratorio con gli chef"
        class="w-full h-44 md:h-64 object-cover"
        onerror={`this.onerror=null;this.src='${base}images/gianfranco-cucina-placeholder.svg';this.classList.remove('object-cover');this.classList.add('object-contain');`}
      />
    </div>

    <!-- Firma -->
    <div class="border-t border-[#C8891A]/30 mt-8 pt-10">
      <p class="text-[#3D3828] text-lg mb-5" style="font-family: 'Lato', sans-serif;">
        Non vedo l'ora di contribuire al successo del tuo ristorante.
      </p>
      <p class="text-[#8A8070] text-lg italic mb-1" style="font-family: 'Playfair Display', serif;">A presto,</p>
      <p class="text-[#1C1A14] text-3xl font-bold" style="font-family: 'Playfair Display', serif;">Gianfranco Ranaldo</p>
      <p class="text-[#C8891A] text-base font-bold uppercase tracking-widest mt-1" style="font-family: 'Lato', sans-serif;">Fondatore di Minicozzi Chef Lab</p>
      <p class="text-[#8A8070] text-base italic mt-1" style="font-family: 'Lato', sans-serif;">Pasta Fresca Su Misura in 72 Ore</p>
    </div>

  </div>
</section>
